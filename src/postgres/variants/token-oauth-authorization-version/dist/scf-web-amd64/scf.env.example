# ===== 腾讯云 SCF Web 函数推荐配置（多用户 issued-token） =====
# 当前项目已切到多用户模式：
# - 不要再在 SCF 环境变量里配置 MCP_SECRET_ID / MCP_SECRET_KEY
# - 不要预置 MCP_API_TOKEN
# - 客户端应在运行时调用 /auth/token-exchange/tencentcloud 获取 MCP_ACCESS_TOKEN

# Web 函数固定监听 0.0.0.0:9000；通常无需修改。
MCP_SERVER_BIND_HOST=0.0.0.0
MCP_SERVER_PORT=9000

# 建议把公网访问地址配置成函数 URL + /sse，方便服务日志打印出的 MCP 配置可直接复用。
# 健康检查地址可直接使用 https://你的函数URL/healthz
# MCP_SERVER_PUBLIC_URL=https://你的函数URL/sse

# ===== 多用户 issued-token 最小配置 =====
MCP_AUTH_MODE=issued-token
TOKEN_EXCHANGE_ENABLED=true
MCP_TOKEN_EXCHANGE_MODE=source-credential
TOKEN_EXCHANGE_ALLOWED_SCOPES=pg.read
READ_ONLY=true

# 服务端只保存运行时换取后的 token / 加密凭证绑定，不预置用户云凭证。
CREDENTIAL_ENCRYPTION_KEY=请替换为32字节AES密钥的base64结果
TOKEN_HASH_PEPPER=请替换为高强度随机串
TOKEN_STORE=sqlite
TOKEN_STORE_PATH=/tmp/postgres-mcp/tokens.db

# 由于 SCF 当前仅有本地 sqlite token store，建议使用较短 TTL。
TOKEN_DEFAULT_TTL_SECONDS=3600
TOKEN_MAX_TTL_SECONDS=43200

# 可选：收紧能力面
SCOPE_ENABLED=false
REGION_SCOPE=
FEATURES=instance,account,database,parameter,backup,monitoring,network,readonly
MCP_STS_REGION=ap-guangzhou

# 可选：更推荐的最小权限收敛（CAM 角色模式）
# 将上面的 MCP_TOKEN_EXCHANGE_MODE 改为 assume-role 后，再补以下变量
# MCP_TOKEN_EXCHANGE_MODE=assume-role
# MCP_ROLE_ARN=qcs::cam::uin/xxx:roleName/xxx
# MCP_ROLE_DURATION_SECONDS=3600
# MCP_ROLE_SESSION_PREFIX=pg-mcp

# 可选：管理员手工签发 / 吊销 token 时再开启
# ADMIN_API_TOKEN=请替换为高强度随机串
