# ===== MCP 数据面鉴权模式 =====
# 可选：none | shared-token | issued-token
# - none         : 不启用数据面鉴权（仅建议本机临时调试）
# - shared-token : 兼容旧模式，所有客户端共用 MCP_API_TOKEN，服务端仍需静态云凭证
# - issued-token : 推荐新模式，客户端先通过 /auth/token-exchange/tencentcloud 换 token，再访问 /sse
MCP_AUTH_MODE=issued-token

# ===== issued-token 动态凭证模式（推荐） =====
# 服务端用于加密保存“用户交换进来的腾讯云凭证”；不是腾讯云 SecretId/SecretKey。
# 建议使用 32 字节随机值的 base64 / base64url 编码结果。
CREDENTIAL_ENCRYPTION_KEY=
# 是否启用腾讯云自助换 token 接口，默认 issued-token 模式下为 true
TOKEN_EXCHANGE_ENABLED=true
# 可选：source-credential | assume-role
# - source-credential: 开发/过渡模式，验证身份后加密保存用户提交的云凭证
# - assume-role      : 推荐生产模式，验证身份后调用 STS AssumeRole，只保存临时凭证
MCP_TOKEN_EXCHANGE_MODE=source-credential
# STS 调用地域
MCP_STS_REGION=ap-guangzhou
# 自助换 token 允许申请的 scopes，默认只开放只读
TOKEN_EXCHANGE_ALLOWED_SCOPES=pg.read
# assume-role 模式下使用
MCP_ROLE_ARN=
MCP_ROLE_SESSION_PREFIX=pg-mcp
MCP_ROLE_DURATION_SECONDS=3600

# ===== 静态云凭证（仅 shared-token / none / 兼容模式使用） =====
MCP_SECRET_ID=
MCP_SECRET_KEY=
# 兼容历史旧变量读取逻辑仍保留，但新部署建议只使用 MCP_SECRET_ID / MCP_SECRET_KEY。

# ===== 兼容旧模式：共享入口 token =====
# 仅当 MCP_AUTH_MODE=shared-token 时使用
MCP_API_TOKEN=
# 如需收紧共享 token 的默认权限，可改成 pg.read 或 pg.read,pg.write
MCP_SHARED_TOKEN_SCOPES=pg.read,pg.write

# ===== issued-token 管理面 =====
# 设置后会启用 /admin/tokens 管理接口，需通过 Authorization: Bearer <ADMIN_API_TOKEN> 访问
ADMIN_API_TOKEN=
# 注意：当前实现中 /admin/tokens 与 /sse 共用 MCP_SERVER_PORT。
ADMIN_BIND_HOST=127.0.0.1
ADMIN_PORT=9000

# ===== Token 存储与签发策略 =====
# 当前仅支持 sqlite；默认会自动创建 data/tokens.db
TOKEN_STORE=sqlite
TOKEN_STORE_PATH=./data/tokens.db
# 可选：给 token hash 再加一层服务端 pepper，增强泄漏后的离线抗碰撞能力
TOKEN_HASH_PEPPER=
# 默认 token TTL（秒）
TOKEN_DEFAULT_TTL_SECONDS=86400
# 最大允许 TTL（秒）
TOKEN_MAX_TTL_SECONDS=2592000
# 未显式指定 scopes 时的默认值
TOKEN_DEFAULT_SCOPES=pg.read

# ===== MCP Server 网络配置 =====
# 本地部署建议保持 127.0.0.1，仅允许本机访问；远程主机 / 容器环境可改为 0.0.0.0。
MCP_SERVER_BIND_HOST=127.0.0.1
MCP_SERVER_PORT=9000
MCP_SERVER_SSE_ENDPOINT=/sse
MCP_SERVER_MESSAGE_ENDPOINT=/message

# 兼容旧变量名（仍可继续使用）
# MCP_SERVER_SSE_PORT=9000

# 部署在远程主机、反向代理或域名后时，可填写最终给 MCP 客户端使用的完整 URL
# 服务启动日志输出的配置，以及 /auth/bootstrap/tencentcloud 返回的 mcp_config，都会优先使用它。
# 例如：https://mcp.example.com/postgres/sse
# MCP_SERVER_PUBLIC_URL=https://your-domain/postgres/sse

# ===== 工具功能组开关（可选） =====
# 留空 = 使用默认工具集；all = 全部开启；或按逗号精确选择：
# instance,account,database,parameter,backup,monitoring,network,readonly
FEATURES=

# ===== Guard 安全画像（可选） =====
# 不需要画像时可留空；默认建议保持只读，并限制服务只对本机开放。
GUARD_PROFILE=

# 开发画像：仅本机调试，不做地域限制；如需写操作，请显式改为 false。
GUARD_DEV_READ_ONLY=true
GUARD_DEV_SCOPE_ENABLED=false
GUARD_DEV_REGION_SCOPE=

# 共享 / 测试画像：建议限定到单一地域，并保持只读。
GUARD_TEST_READ_ONLY=true
GUARD_TEST_SCOPE_ENABLED=true
GUARD_TEST_REGION_SCOPE=ap-xxx

# 未设置 GUARD_PROFILE 时生效的全局默认值（向后兼容）
READ_ONLY=true
SCOPE_ENABLED=false
REGION_SCOPE=

# ===== 客户端侧（不要放进服务端仓库，仅用于示例） =====
# issued-token 模式下，MCP 客户端或本地验证脚本可通过环境变量读取访问 token
# MCP_ACCESS_TOKEN=
