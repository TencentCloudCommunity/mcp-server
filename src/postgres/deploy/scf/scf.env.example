# ===== 腾讯云 SCF Web 函数推荐配置（request-credential + streamable-http） =====
# 当前主分支默认模式：客户端连接 /mcp 时，在 Header 中直传自己的腾讯云凭证。
#
# 服务端（SCF 环境变量）不要配置：
# - MCP_SECRET_ID
# - MCP_SECRET_KEY
# - MCP_API_TOKEN
# - MCP_ACCESS_TOKEN
#
# 客户端在每次请求里附带：
# - X-TencentCloud-Secret-Id
# - X-TencentCloud-Secret-Key
# - X-TencentCloud-Session-Token（可选，临时凭证时使用）

# Web 函数固定使用 streamable-http；不要切换为 stdio 或 sse。
MCP_TRANSPORT=streamable-http
# Web 函数固定监听 0.0.0.0:9000；通常无需修改。
MCP_SERVER_BIND_HOST=0.0.0.0
MCP_SERVER_PORT=9000
MCP_SERVER_HTTP_ENDPOINT=/mcp
MCP_STREAMABLE_HTTP_STATELESS=true

# 建议配置成最终对外访问的 MCP 地址，方便日志或客户端配置复用。
# 客户端必须连接完整 MCP 端点，例如：https://你的函数URL/mcp
# 不要把函数根 URL（https://你的函数URL）直接配给客户端；根路径返回 404 属于预期
# MCP_SERVER_PUBLIC_URL=https://你的函数URL/mcp

# ===== 当前默认鉴权模式 =====
MCP_AUTH_MODE=request-credential
TOKEN_EXCHANGE_ENABLED=false
MCP_REQUEST_VALIDATE_IDENTITY=true

# 建议先以只读权限起步；若需要写能力，再显式追加 pg.write
MCP_REQUEST_CREDENTIAL_SCOPES=pg.read
READ_ONLY=true

# 可选：限制请求凭证允许访问的地域，留空表示不额外限制
MCP_REQUEST_ALLOWED_REGIONS=

# 使用 STS 做 GetCallerIdentity 身份校验时所用地域
MCP_STS_REGION=ap-guangzhou

# 可选：进一步收紧服务暴露面
SCOPE_ENABLED=false
REGION_SCOPE=
FEATURES=instance,account,database,parameter,backup,monitoring,network,readonly
