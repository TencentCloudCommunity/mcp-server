# ===== MCP 传输模式 =====
# 可选：streamable-http | sse | stdio
# - streamable-http：当前主线默认，适合 Hosted URL / Docker / Compose / 远程主机 / SCF
# - sse            ：自建 SSE 兼容模式，仅建议本地或自建服务
# - stdio          ：本地命令直连模式，适合 WorkBuddy / Claude Desktop / Cursor 等本地客户端
MCP_TRANSPORT=streamable-http

# ===== MCP 数据面鉴权模式 =====
# 可选：request-credential | none | shared-token | issued-token
# - request-credential : 当前默认模式。HTTP 下按请求 Header 直传凭证；stdio 下从进程环境读取凭证。
# - none               : 不启用数据面鉴权（仅建议本机临时调试）
# - shared-token       : 兼容共享入口 token；服务端仍使用静态云凭证
# - issued-token       : 旧版 token exchange 动态凭证模式；仅建议 HTTP transport 使用
MCP_AUTH_MODE=request-credential

# ===== request-credential（当前默认） =====
# HTTP / SSE 模式下，客户端每次请求携带：
# - X-TencentCloud-Secret-Id
# - X-TencentCloud-Secret-Key
# - X-TencentCloud-Session-Token（可选）
#
# stdio 模式下，没有 HTTP Header，因此当前进程环境中必须提供：
# - MCP_REQUEST_SECRET_ID / MCP_REQUEST_SECRET_KEY
#   或回退 MCP_SECRET_ID / MCP_SECRET_KEY
MCP_REQUEST_VALIDATE_IDENTITY=true
MCP_REQUEST_CREDENTIAL_SCOPES=pg.read,pg.write
MCP_REQUEST_ALLOWED_REGIONS=
MCP_STS_REGION=ap-guangzhou

# ===== 客户端 / 验证脚本示例变量（不要提交真实值） =====
# cmd/verify、cmd/mcp_smoke、cmd/write_test 会优先读取这组变量。
# 在 stdio 模式下，这组变量也会传给被拉起的本地 server 进程。
MCP_REQUEST_SECRET_ID=
MCP_REQUEST_SECRET_KEY=
MCP_REQUEST_SESSION_TOKEN=

# ===== 兼容模式：静态云凭证（shared-token / none 使用；stdio 可回退复用） =====
MCP_SECRET_ID=
MCP_SECRET_KEY=

# ===== 兼容旧模式：共享入口 token =====
MCP_API_TOKEN=
MCP_SHARED_TOKEN_SCOPES=pg.read,pg.write

# ===== 兼容旧模式：issued-token =====
# 注意：当前主线只在 HTTP transport 下推荐这套能力；stdio 不支持该模式。
CREDENTIAL_ENCRYPTION_KEY=
TOKEN_EXCHANGE_ENABLED=false
MCP_TOKEN_EXCHANGE_MODE=source-credential
TOKEN_EXCHANGE_ALLOWED_SCOPES=pg.read
MCP_ROLE_ARN=
MCP_ROLE_SESSION_PREFIX=pg-mcp
MCP_ROLE_DURATION_SECONDS=3600
ADMIN_API_TOKEN=
ADMIN_BIND_HOST=127.0.0.1
ADMIN_PORT=9000
TOKEN_STORE=sqlite
TOKEN_STORE_PATH=./data/tokens.db
TOKEN_HASH_PEPPER=
TOKEN_DEFAULT_TTL_SECONDS=86400
TOKEN_MAX_TTL_SECONDS=2592000
TOKEN_DEFAULT_SCOPES=pg.read

# ===== MCP Server 网络配置 =====
# streamable-http / sse 使用以下监听地址；stdio 不监听 HTTP 端口。
MCP_SERVER_BIND_HOST=127.0.0.1
MCP_SERVER_PORT=9000
MCP_SERVER_HTTP_ENDPOINT=/mcp
MCP_SERVER_SSE_ENDPOINT=/sse
MCP_SERVER_MESSAGE_ENDPOINT=/message
MCP_STREAMABLE_HTTP_STATELESS=true

# 部署在远程主机、反向代理或域名后时，可填写最终给 MCP 客户端使用的完整 URL。
# 当 transport=sse 时请填写最终 SSE URL，例如：https://mcp.example.com/postgres/sse
# 当 transport=streamable-http 时请填写最终 MCP URL，例如：https://mcp.example.com/postgres/mcp
# MCP_SERVER_PUBLIC_URL=https://your-domain/postgres/mcp

# ===== 工具功能组开关（可选） =====
# 留空 = 使用默认工具集；all = 全部开启；或按逗号精确选择：
# instance,account,database,parameter,backup,monitoring,network,readonly
FEATURES=

# ===== Guard 安全画像（可选） =====
GUARD_PROFILE=

# 开发画像：仅本机调试，不做地域限制；如需写操作，请显式改为 false。
GUARD_DEV_READ_ONLY=true
GUARD_DEV_SCOPE_ENABLED=false
GUARD_DEV_REGION_SCOPE=

# 共享 / 测试画像：建议限定到单一地域，并保持只读。
GUARD_TEST_READ_ONLY=true
GUARD_TEST_SCOPE_ENABLED=true
GUARD_TEST_REGION_SCOPE=ap-xxx

# 未设置 GUARD_PROFILE 时生效的全局默认值（向后兼容）
READ_ONLY=true
SCOPE_ENABLED=false
REGION_SCOPE=
